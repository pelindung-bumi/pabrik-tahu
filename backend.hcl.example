# Copy this file to backend.hcl and fill in your AWS credentials.
# backend.hcl is gitignored — never commit it.
#
# How to get these values:
#   1. Go to AWS Console → IAM → Users → your user → Security credentials
#   2. Create an Access Key with S3 + DynamoDB permissions
#   3. Fill in the values below
#
# Required AWS resources (create once):
#   - S3 bucket:      pabrik-tahu-state       (region: ap-southeast-1)
#   - DynamoDB table: pabrik-tahu-state-lock   (partition key: LockID, type: String)

access_key = "your-aws-access-key-id"
secret_key = "your-aws-secret-access-key"
